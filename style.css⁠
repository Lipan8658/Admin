/* Custom base styles */
body {
  margin: 0;
  -webkit-font-smoothing: antialiased;
}

/* Image Presentation Styles */
.puppet-img {
  width: 100%;
  height: 200px;
  object-fit: cover;
  border: 4px solid #2d3748; /* Dark, thick border */
  border-radius: 12px;
  box-shadow: 6px 6px 0px #2d3748; /* Solid, unblurred shadow */
  filter: saturate(1.3) contrast(1.1); /* vibrant, flatter colors */
  transition: transform 0.2s ease;
  background-color: #fff;
  padding: 4px; /* White gap between image and border */
}

.puppet-img:hover {
  transform: translate(-2px, -2px);
  box-shadow: 8px 8px 0px #2d3748;
}

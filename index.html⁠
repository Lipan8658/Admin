<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Admin Panel - Pure Rasoi</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="stylesheet" href="style.css">
</head>
<body class="bg-gray-100 text-gray-800 font-sans">

  <!-- 🔐 Login Page -->
  <div id="login-page" class="flex h-screen items-center justify-center bg-gray-900">
    <div class="bg-white p-8 rounded-lg shadow-lg text-center max-w-sm w-full mx-4">
      <h1 class="text-2xl font-bold mb-6">Admin Login</h1>
      <button id="login-btn" class="w-full bg-blue-600 text-white px-6 py-3 rounded shadow hover:bg-blue-700 transition font-semibold flex items-center justify-center gap-2">
        <svg class="w-5 h-5 bg-white rounded-full p-0.5" viewBox="0 0 24 24"><path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/><path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/><path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" fill="#FBBC05"/><path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/><path d="M1 1h22v22H1z" fill="none"/></svg>
        Sign in with Google
      </button>
    </div>
  </div>

  <!-- 📊 Main Admin App (Hidden until authenticated) -->
  <div id="main-app" class="hidden min-h-screen flex flex-col md:flex-row">
    
    <!-- 📱 Sidebar Navigation -->
    <aside class="w-full md:w-64 bg-gray-900 text-white flex flex-col transition-all">
      <div class="p-5 text-xl font-bold border-b border-gray-700 flex justify-between items-center">
        <span>Admin Panel</span>
      </div>
      
      <nav class="flex-1 p-4 space-y-2">
        <button id="nav-dashboard" class="w-full text-left p-3 rounded bg-gray-800 font-medium">📊 Dashboard</button>
        <button id="nav-add" class="w-full text-left p-3 rounded hover:bg-gray-800 font-medium">➕ Add Supplier</button>
      </nav>

      <div class="p-4 border-t border-gray-700">
        <div id="user-profile" class="mb-4 text-sm break-words flex items-center gap-2"></div>
        <button id="logout-btn" class="w-full bg-red-600 p-2 rounded hover:bg-red-700 transition">🚪 Logout</button>
      </div>
    </aside>

    <!-- 🖥 Main Content Area -->
    <main class="flex-1 p-6 overflow-y-auto">
      
      <!-- Dashboard View -->
      <section id="view-dashboard" class="block">
        <div class="flex justify-between items-center mb-6">
          <h2 class="text-2xl font-bold">Supplier Dashboard</h2>
          <button id="refresh-data-btn" class="bg-blue-100 text-blue-700 px-3 py-1 rounded hover:bg-blue-200">🔄 Refresh</button>
        </div>
        <div id="suppliers-grid" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
          <!-- Supplier Cards will be injected here via JS -->
          <p class="text-gray-500 col-span-full">Loading suppliers...</p>
        </div>
      </section>

      <!-- Add Supplier View -->
      <section id="view-add-supplier" class="hidden">
        <h2 class="text-2xl font-bold mb-6">Add New Supplier</h2>
        <form id="add-supplier-form" class="bg-white p-6 rounded shadow-md max-w-3xl space-y-6">
          
          <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            <div>
              <label class="block text-sm font-medium mb-1">Supplier Name</label>
              <input type="text" id="sup-name" placeholder="e.g. Pure Rasoi" class="border p-2 rounded w-full" required>
            </div>
            <div>
              <label class="block text-sm font-medium mb-1">Owner Name</label>
              <input type="text" id="sup-owner" placeholder="Owner Name" class="border p-2 rounded w-full">
            </div>
            <div>
              <label class="block text-sm font-medium mb-1">Phone Number</label>
              <input type="text" id="sup-phone" placeholder="10-digit number" class="border p-2 rounded w-full">
            </div>
            <div>
              <label class="block text-sm font-medium mb-1">Price Per Month</label>
              <input type="number" id="sup-price" placeholder="e.g. 5600" class="border p-2 rounded w-full">
            </div>
          </div>

          <div class="border-t pt-4">
            <h3 class="font-semibold mb-3">Location Details</h3>
            <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
              <input type="text" id="sup-state" placeholder="State (e.g. Odisha)" class="border p-2 rounded w-full" required>
              <input type="text" id="sup-city" placeholder="City (e.g. Bargarh)" class="border p-2 rounded w-full" required>
              <input type="text" id="sup-area" placeholder="Area (e.g. Attabira)" class="border p-2 rounded w-full" required>
            </div>
          </div>

          <div class="border-t pt-4">
            <label class="block text-sm font-medium mb-1">Upload Images</label>
            <input type="file" id="sup-images" class="border p-2 rounded w-full bg-gray-50" accept="image/*" multiple>
          </div>

          <p id="upload-status" class="hidden text-sm text-blue-600 font-semibold mb-2"></p>
          
          <button type="submit" class="bg-green-600 text-white px-6 py-2 rounded hover:bg-green-700 transition w-full md:w-auto font-medium shadow">
            Save Supplier
          </button>
        </form>
      </section>

    </main>
  </div>

  <script type="module" src="./app.js"></script>
</body>
</html>

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Admin Panel - Pure Rasoi</title>
  <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gray-100 text-gray-800">

  <!-- Login Page -->
  <div id="login-page" class="flex h-screen items-center justify-center bg-gray-900">
    <div class="bg-white p-8 rounded-lg shadow-lg text-center">
      <h1 class="text-2xl font-bold mb-4">Admin Panel Login</h1>
      <button id="login-btn" class="bg-blue-600 text-white px-6 py-2 rounded shadow hover:bg-blue-700 transition">
        Sign in with Google
      </button>
    </div>
  </div>

  <!-- Dashboard Layout (Hidden by default) -->
  <div id="dashboard-page" class="hidden min-h-screen flex flex-col md:flex-row">
    
    <!-- Sidebar -->
    <aside class="w-full md:w-64 bg-gray-900 text-white flex flex-col">
      <div class="p-4 text-xl font-bold border-b border-gray-700">Admin Panel</div>
      <nav class="flex-1 p-4 space-y-2">
        <button class="w-full text-left p-2 rounded hover:bg-gray-800">📊 Dashboard</button>
        <button class="w-full text-left p-2 rounded hover:bg-gray-800">📁 Suppliers (Docs)</button>
        <button class="w-full text-left p-2 rounded hover:bg-gray-800">➕ Add Supplier</button>
        <button class="w-full text-left p-2 rounded hover:bg-gray-800">🖼 Storage</button>
        <button class="w-full text-left p-2 rounded hover:bg-gray-800">⚙ Settings</button>
      </nav>
      <div class="p-4 border-t border-gray-700">
        <div id="user-profile" class="mb-4 text-sm break-words"></div>
        <button id="logout-btn" class="w-full bg-red-600 p-2 rounded hover:bg-red-700">🚪 Logout</button>
      </div>
    </aside>

    <!-- Main Content -->
    <main class="flex-1 p-6">
      <h2 class="text-2xl font-bold mb-4">Add New Supplier</h2>
      
      <!-- Add Document Form -->
      <form id="add-supplier-form" class="bg-white p-6 rounded shadow-md max-w-2xl space-y-4">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
          <input type="text" id="sup-name" placeholder="Supplier Name (e.g. Pure Rasoi)" class="border p-2 rounded w-full" required>
          <input type="text" id="sup-owner" placeholder="Owner Name" class="border p-2 rounded w-full">
          <input type="text" id="sup-phone" placeholder="Phone Number" class="border p-2 rounded w-full">
          <input type="text" id="sup-state" placeholder="State (e.g. Odisha)" class="border p-2 rounded w-full" required>
          <input type="text" id="sup-city" placeholder="City (e.g. Bargarh)" class="border p-2 rounded w-full" required>
          <input type="text" id="sup-area" placeholder="Area (e.g. Attabira)" class="border p-2 rounded w-full" required>
          <input type="number" id="sup-price" placeholder="Price Per Month" class="border p-2 rounded w-full">
        </div>
        <button type="submit" class="bg-green-600 text-white px-4 py-2 rounded hover:bg-green-700 w-full md:w-auto">
          Save Supplier & Update Location
        </button>
      </form>
    </main>
  </div>

  <script type="module" src="./app.js"></script>
</body>
</html>
